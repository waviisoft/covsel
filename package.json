{
  "name": "covsel-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Runtime-coverage test impact analysis for any JS/TS runner",
  "license": "MIT",
  "author": "WAVIISoft, LLC",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "docs:dev": "pnpm --filter covsel-docs docs:dev",
    "docs:build": "pnpm --filter covsel-docs docs:build",
    "docs:preview": "pnpm --filter covsel-docs docs:preview"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "type": "module"
}
