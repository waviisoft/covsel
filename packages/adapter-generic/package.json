{
  "name": "@covsel/adapter-generic",
  "version": "0.0.0",
  "description": "Level-0 covsel adapter: wrap any runner command via NODE_V8_COVERAGE — zero integration, per-file selection",
  "license": "MIT",
  "author": "WAVIISoft, LLC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@covsel/core": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/waviisoft/covsel.git",
    "directory": "packages/adapter-generic"
  },
  "keywords": [
    "test-impact-analysis",
    "coverage",
    "adapter"
  ],
  "devDependencies": {
    "@types/node": "^22.20.1"
  }
}
