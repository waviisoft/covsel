{
  "name": "@covsel/core",
  "version": "0.0.0",
  "description": "Runner-agnostic core for covsel: Observer, Mapper, Store, Selector, Policy, and the versioned map schema",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/waviisoft/covsel.git",
    "directory": "packages/core"
  },
  "keywords": [
    "test-impact-analysis",
    "tia",
    "coverage",
    "test-selection",
    "v8"
  ],
  "devDependencies": {
    "@types/node": "^22.20.1"
  }
}
